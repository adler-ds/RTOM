# Salesforce Personalization (Decisioning API)
# Base URL: your Data Cloud tenant's Tenant Specific Endpoint (no trailing slash)
# Get it from: Setup > Data Cloud > Developer Information
PERSONALIZATION_BASE_URL=https://your-tenant-specific-endpoint.com

# OAuth 2.0 Client Credentials (recommended, same pattern as Football-Throw-Game)
# Use your Salesforce Connected App credentials
SALESFORCE_CLIENT_ID=your_consumer_key_here
SALESFORCE_CLIENT_SECRET=your_consumer_secret_here
# Optional: override token endpoint (defaults to login.salesforce.com)
# SALESFORCE_TOKEN_ENDPOINT=https://login.salesforce.com/services/oauth2/token
# Optional alternative token endpoint construction
# SALESFORCE_INSTANCE_URL=https://your-instance.my.salesforce.com

# Optional fallback: static bearer token (use only if OAuth client creds are not available)
# PERSONALIZATION_ACCESS_TOKEN=your_access_token

# Server
PORT=3001

# Interactions Web SDK (optional — for /interactions-sdk demo page)
# Copy the CDN script URL from Data Cloud → Website connector → Integration Guide
# INTERACTIONS_SDK_CDN_URL=https://cdn.example.com/path/to/interactions-sdk.js
# INTERACTIONS_DATASPACE=default
# Comma-separated personalization point API names for Personalization.fetch
# INTERACTIONS_PERSONALIZATION_POINTS=Offer_Treatment_Personalization
# Optional first-party cookie domain (leave unset for current host)
# INTERACTIONS_COOKIE_DOMAIN=
