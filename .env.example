# Salesforce Personalization (Decisioning API)
# Base URL: your Data Cloud tenant's Tenant Specific Endpoint (no trailing slash)
# Get it from: Setup > Data Cloud > Developer Information
PERSONALIZATION_BASE_URL=https://your-tenant-specific-endpoint.com

# Bearer token (OAuth 2.0 or Identity Provider)
PERSONALIZATION_ACCESS_TOKEN=your_access_token

# Server
PORT=3001
